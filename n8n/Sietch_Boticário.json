    {
      "parameters": {
        "jsCode": "// O n8n passa os dados em uma lista (mesmo que seja só 1 planta agora). \n// Esse 'for' passa por todas as plantas que chegarem nesse nó.\nfor (const item of $input.all()) {\n  \n  // 1. Pegamos a data da última rega que veio do Firebase\n  const dataUltimaRega = new Date(item.json.ultima_rega);\n  \n  // 2. Pegamos a data e hora de exato momento (Agora)\n  const dataHoje = new Date();\n  \n  // 3. A matemática: subtraímos as datas (o JS calcula em milissegundos)\n  const diferencaTempo = dataHoje.getTime() - dataUltimaRega.getTime();\n  \n  // 4. Convertemos os milissegundos para Dias corridos\n  const diferencaDias = Math.floor(diferencaTempo / (1000 * 3600 * 24));\n  \n  // 5. Criamos dois campos novos no resultado para nos ajudar nos próximos passos!\n  item.json.dias_sem_agua = diferencaDias;\n  \n  // Aqui ele cria um Verdadeiro (true) ou Falso (false)\n  item.json.precisa_regar = diferencaDias >= item.json.intervalo_rega_dias; \n}\n\n// Passamos a bola para o próximo nó\nreturn $input.all();"
      },
