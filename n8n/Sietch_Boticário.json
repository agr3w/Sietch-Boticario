    {
      "parameters": {
        "jsCode": "// 1. Pega o clima do nó de HTTP (Verifique se o nome do nó está exato)\nconst clima = $('HTTP Request').item.json.current;\nconst plantas = $('Get many documents').all();\nconst resultados = [];\n\n// 3. Fazemos a matemática para CADA planta individualmente\nfor (const item of plantas) {\n  const planta = item.json;\n  \n  const dataUltimaRega = new Date(planta.ultima_rega);\n  const dataHoje = new Date();\n  const diferencaDias = Math.floor((dataHoje.getTime() - dataUltimaRega.getTime()) / (1000 * 3600 * 24));\n  \n  let diasParaRegar = planta.intervalo_rega_dias;\n  \n  // Regra climática Fremen\n  if (clima.relative_humidity_2m < 40 && clima.temperature_2m > 25) {\n    diasParaRegar = diasParaRegar - 1;\n  }\n  \n  // 4. Montamos o pacote com TUDO o que precisamos (O ID VOLTOU!)\n  resultados.push({\n    json: {\n      id: planta._id,               // <--- O salvador da pátria!\n      notificar: planta.notificar, // <--- Necessário para o seu nó IF depois\n      planta: planta.nome_apelido,\n      dias_sem_agua: diferencaDias,\n      tolerancia_atual: diasParaRegar,\n      status_alerta: diferencaDias >= diasParaRegar ? \"PRECISA DE ÁGUA!\" : \"Tudo tranquilo\"\n    }\n  });\n}\n\n// Passa a lista completa adiante\nreturn resultados;"
      },
